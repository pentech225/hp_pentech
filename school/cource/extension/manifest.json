{
  "manifest_version": 3,
  "name": "プログラミング 学習ガイド",
  "version": "1.0",
  "description": "Scratchを開いたときに解説パネルを表示します",
  "permissions": ["sidePanel", "tabs"],
  "host_permissions": ["https://scratch.mit.edu/*"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "プログラミング 学習ガイドを開く",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
